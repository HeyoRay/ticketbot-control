{
  "manifest_version": 3,
  "name": "Capital One Ticket Bot",
  "version": "1.0.0",
  "description": "Monitors Capital One Entertainment for ticket availability and auto-clicks when found.",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://entertainment.capitalone.com/*",
    "https://verified.capitalone.com/*",
    "https://api.capitalone.com/*",
    "https://api.pushover.net/*",
    "https://ntfy.sh/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ticket Bot"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}